<?xml version="1.0" encoding="UTF-8"?>
<!--
  waywallen-ipc-v1

  Wire protocol between the waywallen daemon ("manager") and a renderer
  subprocess ("host"). Spoken over a SOCK_STREAM Unix-domain socket the
  daemon bind()s before spawning the subprocess and passes via `--ipc`.

  Role model:
    server  = daemon (waywallen: control plane, lifecycle)
    client  = renderer subprocess (e.g. waywallen-renderer, open-wallpaper-engine
              host). Produces DMA-BUF frames and emits events back.

  Wire format: identical framing to waywallen-display-v1 (Wayland-style
  binary):

    header: 4 bytes
      u16 opcode
      u16 total_length_in_bytes  (including the 4-byte header)

    body: positional args, 4-byte aligned

      u32/i32/f32 = 4 bytes LE
      u64/i64/f64 = 8 bytes LE
      string      = [u32 len_including_NUL] [utf8...] [NUL] [pad to 4]
      array<T>    = [u32 count] [count * sizeof(T)] [pad to 4]

    fds: passed out-of-band via SCM_RIGHTS ancillary data. Order defined
         per-message.

  Invariants:

    - The first Event from the subprocess MUST be `ready`.
    - The subprocess MUST emit at least one `bind_buffers` once Vulkan
      buffer slots have been allocated. The daemon caches the fds and
      `flags` of the latest snapshot for late display subscribers.
    - The subprocess MAY emit additional `bind_buffers` events at any
      later time (e.g. in response to a `configure_buffers` request).
      Each new `bind_buffers` carries a strictly increasing `generation`
      and implicitly retires every prior set; the daemon transparently
      re-binds the new buffer pool to all currently subscribed displays.
    - `frame_ready` events emitted *after* a `bind_buffers` belong to
      that bind's `generation` and MUST NOT reference image_indices from
      a retired generation.
    - Every `frame_ready` MUST carry exactly one acquire sync_fd
      (dma_fence sync_file). v1 does not support sync-less producers.
    - `seq` on `frame_ready` is monotonically increasing.
    - The subprocess MUST emit exactly one `release_syncobj` event after
      `ready` and before any `frame_ready`. The fd is an OPAQUE_FD export
      of a Vulkan timeline semaphore (= a drm_syncobj on Mesa drivers)
      that the subprocess owns and uses to gate dma-buf reuse. Each
      `frame_ready.release_point` names the timeline value the daemon
      will signal once every consumer has finished sampling that frame.
      The subprocess MUST `vkSemaphoreWait` (or equivalent) on
      `release_syncobj@release_point` before re-recording into the same
      `image_index`.

  Version: 3

  v2 (modifier negotiation):
    - Renderer ships `format_caps` event after `ready` and before any
      `bind_buffers`. Carries fourcc/modifier/usage/plane_count grids
      plus device_uuid + sync_caps + color_caps + mem_hints. Daemon
      pairs producer caps with consumer caps and picks a scheme.
    - Daemon dispatches `negotiate_buffers` request — replacement for
      `configure_buffers` — telling the renderer exactly which fourcc,
      modifier, plane_count, sync_mode, color_space, mem_hint, extent
      and pool size to allocate. The renderer answers with a fresh
      `bind_buffers` whose fourcc + modifier match.
    - Renderer replies with `bind_failed` event when it cannot satisfy
      a `negotiate_buffers` (e.g. allocator refuses the modifier on
      this device); daemon blacklists that (fourcc, modifier) pair on
      the renderer and re-runs the picker.
    - `configure_buffers` is retained for the Iter 1+2 transition but
      is dispatch-paused in the daemon; Iter 3 deletes it outright.

  v3 (explicit path negotiation):
    - `negotiate_buffers` carries `path` and `mem_source` — the daemon
      now classifies GPU topology (same-device / same-vendor / cross
      vendor) and selects an explicit allocation path. The bridge in
      the renderer subprocess just executes the directive; no plugin
      ever has to fall back to LINEAR on its own. `path` codes mirror
      `ww_path_category` in <waywallen-bridge/pool.h>:
        0 = OPTIMIZED_SAME_DEVICE  use the daemon-picked tile modifier
        1 = OPTIMIZED_SAME_VENDOR  conservative modifier subset (Iter 2)
        2 = COMPAT_LINEAR          force LINEAR; mem_source picks the source
        3 = COMPAT_CPU_READBACK    Iter 3+, reserved
      `mem_source` codes mirror `ww_mem_source`:
        0 = GPU_NATIVE             GBM render-usage / VK DEVICE_LOCAL
        1 = GPU_LINEAR             GBM_BO_USE_LINEAR / VK LINEAR exportable
        2 = DMABUF_HEAP            /dev/dma_heap/* fallback
    - `format_caps.mem_hints` adds bit 4 = LINEAR_ONLY: producer's own
      modifier-aware probe failed entirely (e.g. NVIDIA proprietary
      where every modifier is external_only); the daemon must pick a
      COMPAT_LINEAR path regardless of consumer caps.
-->
<protocol name="waywallen_ipc" version="3">

  <!-- ==================================================================
       REQUESTS  (daemon -> subprocess, control plane)
       ================================================================== -->

  <!--
    Opening handshake. In v1 this is not required on every connection
    (the daemon currently spawns the subprocess and expects a `ready`
    event without a preceding `hello`), but reserved for future
    reconnect flows.
  -->
  <request name="hello" opcode="1">
    <arg name="client" type="string"/>
    <arg name="version" type="u32"/>
  </request>

  <!--
    Ask the subprocess to load a specific scene. Currently unused by
    the Rust daemon (scene/assets are passed via CLI args at spawn
    time) but the C++ host understands this message.
  -->
  <request name="load_scene" opcode="2">
    <arg name="pkg" type="string"/>
    <arg name="assets" type="string"/>
    <arg name="fps" type="u32"/>
    <arg name="width" type="u32"/>
    <arg name="height" type="u32"/>
  </request>

  <request name="play" opcode="3"/>
  <request name="pause" opcode="4"/>

  <request name="mouse" opcode="5">
    <arg name="x" type="f64"/>
    <arg name="y" type="f64"/>
  </request>

  <request name="set_fps" opcode="6">
    <arg name="fps" type="u32"/>
  </request>

  <!--
    Request clean shutdown. The subprocess is expected to finish the
    current frame, tear down its Vulkan state, and exit. The daemon
    will SIGKILL if the process does not exit quickly.
  -->
  <request name="shutdown" opcode="7"/>

  <!--
    Opcode 8 was `configure_buffers` in v1; v2 deletes it in favor of
    `negotiate_buffers` (opcode 9). The opcode value is reserved.
  -->

  <!--
    Modifier-negotiation v2 — replaces the deleted `configure_buffers`. The
    daemon ships exactly the (fourcc, modifier, plane_count, sync_mode,
    color, mem_hint, extent, count) tuple it picked from the producer ∩
    consumer caps intersection. The renderer answers with a fresh
    `bind_buffers` whose fourcc + modifier match (and a strictly
    increasing `generation`). On failure the renderer sends
    `bind_failed` (opcode 7); the daemon then blacklists the
    (fourcc, modifier) pair on this renderer and tries again.

    Field meanings:
      `fourcc`        — DRM_FORMAT_* (canonical: ABGR8888 = 'AB24' = 0x34324241).
      `modifier`      — DRM_FORMAT_MOD_* (LINEAR = 0; INVALID/0xff..ff = "implicit, allocator picks").
      `plane_count`   — # planes for this fourcc/modifier combo (1 for RGBA).
      `sync_mode`     — see `format_caps.sync_caps` bits below; exactly one bit.
      `color`         — packed encoding/range/alpha; see `format_caps.color_caps`.
      `mem_hint`      — bitfield: same bits as `format_caps.mem_hints`.
      `extent_w/h`    — pixel extent of each buffer.
      `count`         — pool size (number of buffers in the swapchain).
      `path`          — v3, see `ww_path_category` codes in the v3 doc
                        block above. Bridge dispatches its allocation
                        path purely on this; modifier is the operand.
      `mem_source`    — v3, see `ww_mem_source` codes. Picks the
                        underlying memory backend for COMPAT_LINEAR.
  -->
  <request name="negotiate_buffers" opcode="9">
    <arg name="fourcc" type="u32"/>
    <arg name="modifier" type="u64"/>
    <arg name="plane_count" type="u32"/>
    <arg name="sync_mode" type="u32"/>
    <arg name="color" type="u32"/>
    <arg name="mem_hint" type="u32"/>
    <arg name="extent_w" type="u32"/>
    <arg name="extent_h" type="u32"/>
    <arg name="count" type="u32"/>
    <arg name="path" type="u32"/>
    <arg name="mem_source" type="u32"/>
  </request>


  <!-- ==================================================================
       EVENTS  (subprocess -> daemon)
       ================================================================== -->

  <!--
    Emitted once the subprocess has finished initializing Vulkan and is
    ready to receive control messages. The DRM render-node major/minor
    of the VkPhysicalDevice the subprocess picked are reported so the
    daemon can decide whether displays subscribed to this renderer are
    on the same GPU (zero-copy via DEVICE_LOCAL) or a different GPU
    (must round-trip through HOST_VISIBLE / GTT).

    A subprocess that cannot resolve its render node (driver lacks
    `VK_EXT_physical_device_drm`) MUST send `(0, 0)`; the daemon then
    treats every consumer as cross-GPU and forces host-visible
    placement.
  -->
  <event name="ready" opcode="1">
    <arg name="drm_render_major" type="u32"/>
    <arg name="drm_render_minor" type="u32"/>
  </event>

  <!--
    Carries the full set of swapchain image fds as SCM_RIGHTS ancillary
    data. The first `bind_buffers` follows shortly after `ready`;
    subsequent ones follow a `configure_buffers` request from the
    daemon (see Invariants). Each bind_buffers retires every prior
    generation. fds live for the lifetime of the snapshot.

    `generation` is strictly monotonic per renderer (starts at 1 for
    the first bind, +1 for each subsequent re-export).

    `flags` is the current placement flag set the subprocess used when
    allocating the exported memory; mirrors the `flags` of the
    `configure_buffers` request that triggered the re-export. See
    `configure_buffers` for bit semantics.

    Multi-plane modifiers (e.g. AMD DCC where plane 0 is colour data
    and plane 1 is the DCC compression metadata) are flattened into
    the parallel arrays: each of `stride`, `plane_offset`, `size`
    has `count * planes_per_buffer` entries indexed
    `[buffer_idx * planes_per_buffer + plane_idx]`. The fd array
    follows the same flattening — `count * planes_per_buffer` fds
    arrive via SCM_RIGHTS. For modifiers backed by a single memory
    allocation (the common case on AMD/Intel), the renderer dups the
    same dma-buf fd into every plane slot.
  -->
  <event name="bind_buffers" opcode="2">
    <arg name="generation" type="u64"/>
    <arg name="flags" type="u32"/>
    <arg name="count" type="u32"/>
    <arg name="fourcc" type="u32"/>
    <arg name="width" type="u32"/>
    <arg name="height" type="u32"/>
    <arg name="modifier" type="u64"/>
    <arg name="planes_per_buffer" type="u32"/>
    <arg name="stride" type="array" element="u32"/>
    <arg name="plane_offset" type="array" element="u32"/>
    <arg name="size" type="array" element="u64"/>
    <fds count_expr="count * planes_per_buffer"/>
  </event>

  <!--
    A frame was produced. `image_index` indexes into the fd array
    delivered by the preceding `bind_buffers`. Always carries exactly
    one sync_fd (dma_fence sync_file) as SCM_RIGHTS — the acquire fence
    that consumers must wait on before sampling.

    `release_point` is the timeline value the daemon will signal on the
    `release_syncobj` (see opcode 5) once every consumer subscribed at
    `frame_ready` time has finished its GPU work. The producer MUST
    record the (image_index, release_point) pair and gate the next
    submit into `image_index` on `release_syncobj@release_point`.
  -->
  <event name="frame_ready" opcode="3">
    <arg name="image_index" type="u32"/>
    <arg name="seq" type="u64"/>
    <arg name="ts_ns" type="u64"/>
    <arg name="release_point" type="u64"/>
    <fds count="1"/>
  </event>

  <event name="error" opcode="4">
    <arg name="msg" type="string"/>
  </event>

  <!--
    Export the producer-owned timeline drm_syncobj used to gate dma-buf
    reuse. Sent exactly once per connection, after `ready` and before
    any `frame_ready`. The fd is `VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_OPAQUE_FD`
    of a Vulkan TIMELINE semaphore (which on Mesa is backed by a
    drm_syncobj — the daemon manipulates it via `DRM_IOCTL_SYNCOBJ_*`
    rather than re-importing into Vulkan).

    The daemon merges every consumer's release fence for a frame and
    transfers the merged fence to `release_point` on this syncobj using
    `DRM_IOCTL_SYNCOBJ_TRANSFER`. The producer's later submit that
    re-uses the same `image_index` waits on the same point.
  -->
  <event name="release_syncobj" opcode="5">
    <fds count="1"/>
  </event>

  <!--
    Producer capability declaration — sent exactly once after `ready`
    and before any `bind_buffers`. Communicates everything the daemon
    needs to pair this renderer with consumers and pick a transferable
    DMA-BUF descriptor.

    Encoding:
      Parallel arrays. `fourccs[i]` advertises a DRM format the
      producer can allocate; `mod_counts[i]` is the number of modifiers
      it supports for that format. Modifiers/usages/plane_counts are
      flattened fourcc-major:

        modifiers[ sum(mod_counts[0..i]) .. +mod_counts[i] ]
        usages[    same range ]
        plane_counts[ same range ]

      Validation: modifiers.len == usages.len == plane_counts.len ==
      sum(mod_counts).

    Bit definitions (mirrored across producer + consumer caps):
      `usage` per (fourcc, modifier):
        bit 0 = SAMPLED               can be sampled from a shader
        bit 1 = STORAGE               GPU storage image
        bit 2 = COLOR_ATTACHMENT      can be rendered into
        bit 3 = DEPTH_STENCIL         depth/stencil target
        bit 4 = TRANSFER_SRC          blit source
        bit 5 = TRANSFER_DST          blit destination
        bit 6 = SCANOUT               can be directly scanned out by KMS
      `mem_hints`:
        bit 0 = DEVICE_LOCAL          producer prefers VRAM placement
        bit 1 = HOST_VISIBLE          producer can also do GTT/system
        bit 2 = SCANOUT_CAPABLE       producer can place in scanout-able mem
        bit 3 = PROTECTED             reserved (DRM/HDCP)
        bit 4 = LINEAR_ONLY           v3: producer's modifier-aware probe
                                       returned no usable entries (e.g. every
                                       modifier external_only); daemon must
                                       pick COMPAT_LINEAR.
      `sync_caps`:
        bit 0 = IMPLICIT              dma_fence on dma-buf
        bit 1 = SYNCOBJ_BINARY        binary drm_syncobj fd (one-shot)
        bit 2 = SYNCOBJ_TIMELINE      timeline drm_syncobj (multi-point)
      `color_caps` (packed; OR together):
        bits 0..3 = encoding bitset:    sRGB | linear | BT601 | BT709 | BT2020 (...)
        bits 4..5 = range bitset:       full | limited
        bit 6     = ALPHA_PREMULTIPLIED supported
        bit 7     = ALPHA_STRAIGHT      supported

    Device identity:
      `device_uuid` / `driver_uuid` — 16 bytes each, encoded as 4×u32
      LE for codegen friendliness. Source: Vulkan
      `VkPhysicalDeviceIDProperties.{deviceUUID,driverUUID}`. All zeros
      means "unknown" — the daemon falls back to drm_render major:minor.
  -->
  <event name="format_caps" opcode="6">
    <arg name="fourccs" type="array" element="u32"/>
    <arg name="mod_counts" type="array" element="u32"/>
    <arg name="modifiers" type="array" element="u64"/>
    <arg name="usages" type="array" element="u32"/>
    <arg name="plane_counts" type="array" element="u32"/>
    <arg name="device_uuid" type="array" element="u32"/>
    <arg name="driver_uuid" type="array" element="u32"/>
    <arg name="drm_render_major" type="u32"/>
    <arg name="drm_render_minor" type="u32"/>
    <arg name="mem_hints" type="u32"/>
    <arg name="sync_caps" type="u32"/>
    <arg name="color_caps" type="u32"/>
    <arg name="extent_max_w" type="u32"/>
    <arg name="extent_max_h" type="u32"/>
  </event>

  <!--
    Renderer-side report that a `negotiate_buffers` could not be
    satisfied. Non-terminal: the daemon adds (fourcc, modifier) to
    this renderer's per-peer blacklist and re-runs `negotiate::pick`.
    `reason` codes:
      0 = import_failed       allocator/driver refused the modifier
      1 = oom                 system / device memory exhausted
      2 = feature_unsupported (rare) sync_mode / color / mem_hint
                              required by the negotiation isn't
                              actually available on this device
      3 = other               see `message` for details
  -->
  <event name="bind_failed" opcode="7">
    <arg name="fourcc" type="u32"/>
    <arg name="modifier" type="u64"/>
    <arg name="reason" type="u32"/>
    <arg name="message" type="string"/>
  </event>

</protocol>
